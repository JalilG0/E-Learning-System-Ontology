# --- Ödevler, Teslimler ve Notlar ---
:CS550_Project rdf:type :Assignment ;
               :dueDate "2026-06-15T23:59:00"^^xsd:dateTime .
:CS550 :hasAssignment :CS550_Project .

:Sub_Jalil_CS550 rdf:type :Submission ;
                 :submittedBy :Student_Jalil ;
                 :submissionFor :CS550_Project ;
                 :submissionDate "2026-06-05T10:00:00"^^xsd:dateTime ;
                 :hasGrade :Grade_Jalil_CS550 .

:Grade_Jalil_CS550 rdf:type :Grade ;
